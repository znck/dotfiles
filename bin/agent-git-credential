#!/usr/bin/env bash

set -euo pipefail

AGENT_EMAIL="${ZNCK_AGENT_EMAIL:-295982911+znck-agent[bot]@users.noreply.github.com}"
remote="${AGENT_GITHUB_REMOTE:-origin}"

action="${1:-get}"

if [ "${action}" != "get" ]; then
  exit 0
fi

protocol=""
host=""

while IFS='=' read -r key value; do
  case "${key}" in
    protocol) protocol="${value}" ;;
    host) host="${value}" ;;
  esac
done

if [ "${protocol}" != "https" ] || [ "${host}" != "github.com" ]; then
  exit 0
fi

case "${ZNCK_AGENT_MODE:-}" in
  1 | true | yes | agent) ;;
  *)
    if [ "$(git config --get user.email 2>/dev/null || true)" != "${AGENT_EMAIL}" ]; then
      exit 0
    fi
    ;;
esac

token="$(agent-github-token.mts "${remote}" 2>/dev/null)" || exit 0

printf 'username=x-access-token\n'
printf 'password=%s\n' "${token}"
