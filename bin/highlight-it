#!/usr/bin/env bash

set -euo pipefail

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  echo "Usage: highlight-it <syntax> [file]" >&2
  exit 2
fi

syntax="$1"

if [ "$#" -eq 2 ]; then
  src=(cat "$2")
else
  src=(pbpaste)
fi

"${src[@]}" |
  highlight -O rtf --syntax "$syntax" --font 'Fira Code' --style solarized-light --font-size 28 |
  pbcopy
